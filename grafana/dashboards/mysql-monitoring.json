        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (instance, schema) (mysql_info_schema_table_size{schema!~\"information_schema|performance_schema|mysql|sys\"})",
          "legendFormat": "{{instance}} / {{schema}}",
          "refId": "A"
        }
      ],
