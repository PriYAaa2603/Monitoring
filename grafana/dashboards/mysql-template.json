        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (instance, schema) (mysql_info_schema_table_size{instance=~\"$instance\", schema=~\"$schema\", schema!~\"information_schema|performance_schema|mysql|sys\"})",
          "legendFormat": "{{instance}} / {{schema}}",
          "refId": "A"
        }
      ],
      "title": "Database Size per Instance",
      "type": "timeseries"
