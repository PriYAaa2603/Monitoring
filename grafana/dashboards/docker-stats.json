{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Replicates `docker stats` columns for the MariaDB containers: CPU %, Mem Usage, Mem Limit, Mem %, Net I/O (Rx/Tx), Block I/O (Read/Write), PIDs. Data from Telegraf Docker input via Prometheus. Net and Block I/O are current rate (bytes/sec). Source: Docker Stats API — works on Docker Desktop for Windows.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Snapshot table equivalent to `docker stats mysql-instance-1 mysql-instance-2 mysql-instance-3`. Auto-refreshes every 5 s.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "left",
            "cellOptions": { "type": "auto" },
            "filterable": false,
            "inspect": false,
            "minWidth": 110
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "text", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Container" },
            "properties": [
              { "id": "custom.width", "value": 175 },
              { "id": "custom.align", "value": "left" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "CPU %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 2 },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 100 },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "gradient" }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 50 },
                    { "color": "red", "value": 80 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Mem Usage" },
            "properties": [
              { "id": "unit", "value": "bytes" },
              { "id": "decimals", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Mem Limit" },
            "properties": [
              { "id": "unit", "value": "bytes" },
              { "id": "decimals", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Mem %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 1 },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 100 },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "gradient" }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 60 },
                    { "color": "red", "value": 85 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Net Rx" },
            "properties": [
              { "id": "unit", "value": "Bps" },
              { "id": "decimals", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Net Tx" },
            "properties": [
              { "id": "unit", "value": "Bps" },
              { "id": "decimals", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Block Read" },
            "properties": [
              { "id": "unit", "value": "Bps" },
              { "id": "decimals", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Block Write" },
            "properties": [
              { "id": "unit", "value": "Bps" },
              { "id": "decimals", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "PIDs" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "decimals", "value": 0 }
            ]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "cellHeight": "md",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": ["sum"],
          "show": false
        },
        "showHeader": true,
        "sortBy": [{ "desc": false, "displayName": "Container" }]
      },
      "pluginVersion": "10.4.2",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "docker_container_cpu_usage_percent{container_name=~\"mysql-instance-[123]\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "docker_container_mem_usage{container_name=~\"mysql-instance-[123]\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "docker_container_mem_limit{container_name=~\"mysql-instance-[123]\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "docker_container_mem_usage_percent{container_name=~\"mysql-instance-[123]\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(docker_container_net_rx_bytes{container_name=~\"mysql-instance-[123]\"}[1m])) by (container_name)",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "E"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(docker_container_net_tx_bytes{container_name=~\"mysql-instance-[123]\"}[1m])) by (container_name)",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "F"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(docker_container_blkio_io_service_bytes_recursive_read{container_name=~\"mysql-instance-[123]\"}[1m])) by (container_name)",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "G"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(docker_container_blkio_io_service_bytes_recursive_write{container_name=~\"mysql-instance-[123]\"}[1m])) by (container_name)",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "H"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "docker_container_status_n_pids{container_name=~\"mysql-instance-[123]\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "I"
        }
      ],
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": {
            "include": { "pattern": "^(container_name|Value.*)$" }
          }
        },
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": {
              "container_name": 0,
              "Value #A": 1,
              "Value #B": 2,
              "Value #C": 3,
              "Value #D": 4,
              "Value #E": 5,
              "Value #F": 6,
              "Value #G": 7,
              "Value #H": 8,
              "Value #I": 9
            },
            "renameByName": {
              "container_name": "Container",
              "Value #A": "CPU %",
              "Value #B": "Mem Usage",
              "Value #C": "Mem Limit",
              "Value #D": "Mem %",
              "Value #E": "Net Rx",
              "Value #F": "Net Tx",
              "Value #G": "Block Read",
              "Value #H": "Block Write",
              "Value #I": "PIDs"
            }
          }
        }
      ],
      "title": "docker stats — MariaDB Containers",
      "type": "table"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["docker", "containers", "telegraf"],
  "templating": { "list": [] },
  "time": { "from": "now-5m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Docker Stats — MariaDB Containers",
  "uid": "docker-stats-mariadb",
  "version": 1
}
